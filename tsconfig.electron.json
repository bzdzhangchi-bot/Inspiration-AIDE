{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "outDir": "dist-electron",
    "sourceMap": true,

    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/main/**/*.ts", "src/shared/**/*.ts"]
}
